{
  "info": {
    "name": "Carpool Demo 全量接口",
    "description": "拼车 Demo 全部 HTTP 接口。K8s 部署时 baseUrl 设为 http://127.0.0.1:30080（需 kubectl port-forward gateway）。本地 IDEA 开发用 http://localhost:8080。\n\n推荐测试顺序：\n1. 乘客/司机/管理员 登录（自动保存 Token）\n2. 司机 上线 → 上报位置\n3. 乘客 发单（自动保存 tripId）\n4. 司机 接单 → 到达 → 开始 → 完单\n5. 乘客 评价\n\n测试账号：\n- 乘客 passenger1/123456（余额500）\n- 司机 driver1/123456（需已审核 APPROVED）\n- 管理员 admin/admin123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:30080" },
    { "key": "passengerToken", "value": "" },
    { "key": "driverToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "tripId", "value": "1" },
    { "key": "passengerId", "value": "1" },
    { "key": "driverId", "value": "1" }
  ],
  "item": [
    {
      "name": "00-健康检查",
      "item": [
        {
          "name": "Gateway 健康检查",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health",
            "description": "无需 Token。K8s 需先 port-forward gateway。"
          }
        }
      ]
    },
    {
      "name": "01-乘客",
      "item": [
        {
          "name": "登录",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var j = pm.response.json();",
                "if (j.data && j.data.token) {",
                "  pm.collectionVariables.set('passengerToken', j.data.token);",
                "  if (j.data.passengerId) pm.collectionVariables.set('passengerId', j.data.passengerId);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/passenger/auth/login?username=passenger1&password=123456",
            "description": "公开接口，无需 Token。返回 token、passengerId。"
          }
        },
        {
          "name": "发单",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var j = pm.response.json();",
                "if (j.data && j.data.id) pm.collectionVariables.set('tripId', j.data.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": "{{baseUrl}}/api/passenger/trips?startPoint=北京市天安门&endPoint=广州南站",
            "description": "需乘客 Token。跨城地址请写「北京市xxx」。同城可写「广州大学城」→「广州南站」。"
          }
        },
        {
          "name": "行程列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": "{{baseUrl}}/api/passenger/trips"
          }
        },
        {
          "name": "行程详情",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": "{{baseUrl}}/api/passenger/trips/{{tripId}}"
          }
        },
        {
          "name": "取消行程",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": "{{baseUrl}}/api/passenger/trips/{{tripId}}/cancel",
            "description": "仅 CREATED / DISPATCHING 状态可取消。"
          }
        },
        {
          "name": "评价行程",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": "{{baseUrl}}/api/passenger/trips/{{tripId}}/rate?rating=5",
            "description": "行程 COMPLETED 后可评价，rating 1-5。"
          }
        },
        {
          "name": "查询本单司机位置",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": "{{baseUrl}}/api/passenger/trips/{{tripId}}/driver-location",
            "description": "行程 ACCEPTED/ARRIVED/IN_PROGRESS 且司机已上报位置。地图建议每 60 秒轮询。"
          }
        }
      ]
    },
    {
      "name": "02-司机",
      "item": [
        {
          "name": "登录",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var j = pm.response.json();",
                "if (j.data && j.data.token) {",
                "  pm.collectionVariables.set('driverToken', j.data.token);",
                "  if (j.data.driverId) pm.collectionVariables.set('driverId', j.data.driverId);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/driver/auth/login?username=driver1&password=123456"
          }
        },
        {
          "name": "上线",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/online",
            "description": "接单前必须先上线。"
          }
        },
        {
          "name": "上报位置",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/location?location=113.277732,22.989125",
            "description": "格式：经度,纬度。需先上线。"
          }
        },
        {
          "name": "下线",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/offline"
          }
        }
      ]
    },
    {
      "name": "03-司机行程",
      "item": [
        {
          "name": "待接单列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/trips/pending"
          }
        },
        {
          "name": "接单",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/trips/{{tripId}}/accept",
            "description": "tripId 用发单返回的 data.id。"
          }
        },
        {
          "name": "到达上车点",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/trips/{{tripId}}/arrive"
          }
        },
        {
          "name": "开始行程",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/trips/{{tripId}}/start"
          }
        },
        {
          "name": "完单",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": "{{baseUrl}}/api/driver/trips/{{tripId}}/complete",
            "description": "触发 Seata 全局事务：扣乘客余额 + 司机入账。"
          }
        }
      ]
    },
    {
      "name": "04-地图",
      "item": [
        {
          "name": "地理编码",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/map/geocode?address=广州南站",
            "description": "公开接口。短地址默认按广州检索，跨城请写「北京市天安门」。"
          }
        },
        {
          "name": "路线规划",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/map/route?origin=北京市天安门&destination=广州南站",
            "description": "公开接口。返回里程、时长、预估费用。"
          }
        },
        {
          "name": "在线司机位置列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/map/drivers/locations",
            "description": "公开接口。地图页每 60 秒轮询，返回所有在线且已上报位置的司机。"
          }
        },
        {
          "name": "天气与调价倍率",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/map/weather?lat=23.13&lon=113.27",
            "description": "公开接口。返回 OpenWeather 天气及建议价格倍率。"
          }
        }
      ]
    },
    {
      "name": "05-管理员",
      "item": [
        {
          "name": "登录",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var j = pm.response.json();",
                "if (j.data && j.data.token) pm.collectionVariables.set('adminToken', j.data.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/auth/login?username=admin&password=admin123"
          }
        },
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/dashboard"
          }
        },
        {
          "name": "行程列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/trips?status=DISPATCHING&page=1&size=20"
          }
        },
        {
          "name": "行程详情",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/trips/{{tripId}}"
          }
        },
        {
          "name": "司机列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/drivers?auditStatus=PENDING&page=1&size=20"
          }
        },
        {
          "name": "司机审核",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/drivers/{{driverId}}/audit?auditStatus=APPROVED",
            "description": "auditStatus: PENDING / APPROVED / REJECTED"
          }
        },
        {
          "name": "乘客列表",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/passengers?page=1&size=20"
          }
        },
        {
          "name": "封禁/解封乘客",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/passengers/{{passengerId}}/ban?banned=true"
          }
        },
        {
          "name": "查询计价规则",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/pricing"
          }
        },
        {
          "name": "修改计价规则",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/pricing?baseFare=8&perKmRate=2.0&minFare=15"
          }
        }
      ]
    },
    {
      "name": "06-内部接口-乘客",
      "description": "微服务间 Feign 调用接口，Gateway 对 /api/internal/** 不做 JWT 校验。仅供开发调试，生产勿暴露。",
      "item": [
        {
          "name": "查询信用分",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/passenger/credit?passengerId={{passengerId}}"
          }
        },
        {
          "name": "校验余额",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/passenger/balance/check?passengerId={{passengerId}}&amount=50"
          }
        },
        {
          "name": "扣减余额",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/internal/passenger/deduct?passengerId={{passengerId}}&amount=10"
          }
        },
        {
          "name": "乘客列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/passenger/list?page=1&size=20"
          }
        },
        {
          "name": "封禁乘客",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/internal/passenger/{{passengerId}}/ban?banned=true"
          }
        },
        {
          "name": "乘客统计",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/passenger/stats"
          }
        }
      ]
    },
    {
      "name": "07-内部接口-司机",
      "item": [
        {
          "name": "是否在线",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/driver/online/check?driverId={{driverId}}"
          }
        },
        {
          "name": "司机入账",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/internal/driver/credit?driverId={{driverId}}&amount=10"
          }
        },
        {
          "name": "司机列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/driver/list?auditStatus=APPROVED&page=1&size=20"
          }
        },
        {
          "name": "司机审核",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/internal/driver/{{driverId}}/audit?auditStatus=APPROVED"
          }
        },
        {
          "name": "司机统计",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/driver/stats"
          }
        },
        {
          "name": "查询司机位置",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/driver/{{driverId}}/location"
          }
        },
        {
          "name": "在线司机位置列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/driver/locations/online"
          }
        }
      ]
    },
    {
      "name": "08-内部接口-行程",
      "item": [
        {
          "name": "行程列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/trip/list?status=COMPLETED&page=1&size=20"
          }
        },
        {
          "name": "行程详情",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/trip/{{tripId}}"
          }
        },
        {
          "name": "行程统计",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/trip/stats"
          }
        },
        {
          "name": "查询计价规则",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/internal/trip/pricing"
          }
        },
        {
          "name": "修改计价规则",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/internal/trip/pricing?baseFare=8&perKmRate=2.0&minFare=15"
          }
        }
      ]
    }
  ]
}
